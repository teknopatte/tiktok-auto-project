{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "type", "objective", "acceptance_criteria", "test_focus", "scientist_required", "commit_description"],
  "properties": {
    "id": {"type": "string", "pattern": "^M-[0-9]{3,}$"},
    "title": {"type": "string", "minLength": 1},
    "type": {"type": "string", "enum": ["AUDIT_ONLY", "IMPLEMENTATION", "FIX", "DOCUMENTATION", "EXPERIMENT"]},
    "objective": {"type": "string", "minLength": 1},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "test_focus": {"type": "array", "items": {"type": "string"}},
    "scientist_required": {"type": "boolean"},
    "commit_description": {"type": "string", "minLength": 1, "maxLength": 72}
  }
}
