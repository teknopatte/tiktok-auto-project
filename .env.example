# Copy this file to .env and fill values locally.

# Local folder where downloaded videos will be stored.
# You can set this to a synced Google Drive / OneDrive folder.
VIDEO_OUTPUT_ROOT=downloads/youtube

# How fresh a video must be to be downloaded.
YOUTUBE_SINCE_HOURS=24

# Only checks the latest N videos per channel.
YOUTUBE_MAX_VIDEOS_PER_CHANNEL=1

# Download format optimized for TikTok processing.
YOUTUBE_DOWNLOAD_FORMAT=bv*[height<=1080]+ba/b[height<=1080]/b

# Optional, useful if YouTube blocks anonymous extraction.
# Values: chrome, edge, firefox, brave, chromium, opera, safari, vivaldi
YOUTUBE_COOKIES_FROM_BROWSER=

# Optional pause between channel checks.
YOUTUBE_SLEEP_SECONDS=0

# Segment duration used after a successful download.
CLIP_SEGMENT_SECONDS=60

# Local folder containing Trackmania/satisfying videos for the bottom half.
SATISFYING_VIDEO_ROOT=videos_satisfaisantes

# TikTok official Content Posting API.
# The app must be approved for video.publish and the account must authorize it.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://tiktok.aemour.com/tiktok/callback/
TIKTOK_LOCAL_CALLBACK_URL=http://127.0.0.1:8787/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish,video.list
TIKTOK_ACCESS_TOKEN=
TIKTOK_AUTO_PUBLISH=0
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_CAPTION_TEMPLATE={title} #{niche} #fyp
TIKTOK_PUBLISH_LIMIT=1
TIKTOK_DISABLE_COMMENT=0
TIKTOK_DISABLE_DUET=0
TIKTOK_DISABLE_STITCH=0
TIKTOK_IS_AIGC=0
